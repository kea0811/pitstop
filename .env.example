# ── Supabase (auth + photo storage fallback) ────────────────────────────────
# Project settings → API. Both are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Cloudflare R2 (preferred photo storage; egress-free) ─────────────────────
# When all five are set, photos upload to R2 via a presigned PUT and render
# from R2_PUBLIC_URL. If any is missing, uploads fall back to Supabase Storage.
# R2 → Manage API tokens for the key/secret; enable a public r2.dev URL or a
# custom domain on the bucket for R2_PUBLIC_URL.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=gotham-garage-photos
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# ── MongoDB (collection data) ────────────────────────────────────────────────
# e.g. from Railway. Include the db name in the path (…/pitstop?authSource=admin).
MONGODB_URI=mongodb://user:password@host:port/pitstop?authSource=admin

# ── upcitemdb (optional) ─────────────────────────────────────────────────────
# Trial endpoint needs no key but is limited to ~100 lookups/day per source IP
# (shared on Vercel). Set a paid key to switch to the authenticated v1 API with
# a real per-key quota — barcode lookups are cached forever and searches for a
# week, so most installs never need this.
# UPCITEMDB_KEY=your-upcitemdb-api-key
# UPCITEMDB_BASE=https://api.upcitemdb.com/prod/trial
